<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ calendar.name }} — Climate Solutions</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: system-ui, -apple-system, sans-serif;
            background: #f0f4f0;
            color: #1b1b1b;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        header {
            background: #1b4332;
            color: #fff;
            padding: 1rem 2rem;
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        header .brand { font-weight: 700; font-size: 1.1rem; color: #95d5b2; text-decoration: none; }
        header .brand:hover { color: #fff; }
        main { flex: 1; padding: 2rem; max-width: 960px; margin: 0 auto; width: 100%; }
        footer {
            text-align: center;
            padding: 1rem;
            font-size: .875rem;
            color: #555;
            border-top: 1px solid #d8e8d8;
            margin-top: 3rem;
        }

        .page-heading { margin-bottom: 1.5rem; }
        .page-heading h1 { font-size: 1.6rem; font-weight: 700; color: #1b4332; }
        .page-heading .client-name { font-size: 1rem; color: #555; margin-top: .3rem; }

        .flash-list { list-style: none; margin-bottom: 1.25rem; }
        .flash-list li { padding: .75rem 1rem; border-radius: 4px; margin-bottom: .5rem; font-size: .9rem; }
        .flash-success { background: #d1fae5; color: #065f46; }

        #calendar-holder {
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,.08);
            padding: 1.5rem;
            margin-bottom: 2rem;
        }
        .fc-toolbar-title { color: #1b4332 !important; }
        .fc-button-primary {
            background-color: #2d6a4f !important;
            border-color: #2d6a4f !important;
        }
        .fc-button-primary:hover {
            background-color: #1b4332 !important;
            border-color: #1b4332 !important;
        }
        .fc-button-active {
            background-color: #1b4332 !important;
            border-color: #1b4332 !important;
        }
        .fc-daygrid-event { border-radius: 4px; cursor: pointer; }

        .booking-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.45);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }
        .booking-overlay.is-open { display: flex; }
        .booking-panel {
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 4px 24px rgba(0,0,0,.15);
            padding: 1.5rem;
            width: 90%;
            max-width: 480px;
        }
        .booking-panel h3 { font-size: 1.1rem; font-weight: 700; color: #1b4332; margin-bottom: 1rem; }
        .booking-panel .slot-info { font-size: .85rem; color: #555; margin-bottom: 1rem; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem; margin-bottom: .75rem; }
        .form-field label { display: block; font-size: .78rem; font-weight: 600; margin-bottom: .25rem; color: #374151; }
        .form-field input,
        .form-field textarea {
            width: 100%;
            padding: .4rem .6rem;
            border: 1px solid #d1d5db;
            border-radius: 4px;
            font-size: .875rem;
        }
        .form-field textarea { resize: vertical; min-height: 64px; }
        .form-field-full { grid-column: 1 / -1; }
        .btn-submit {
            background: #1b4332; color: #fff; border: none; border-radius: 4px;
            padding: .45rem .95rem; font-size: .875rem; font-weight: 600; cursor: pointer;
        }
        .btn-submit:hover { background: #155724; }
        .btn-cancel {
            background: transparent; color: #6b7280; border: 1px solid #d1d5db; border-radius: 4px;
            padding: .45rem .95rem; font-size: .875rem; font-weight: 600; cursor: pointer;
            margin-left: .5rem;
        }
        .btn-cancel:hover { background: #f3f4f6; }
        .booking-actions { margin-top: 1rem; display: flex; gap: .5rem; }
    </style>
</head>
<body>
    <header>
        <span class="brand">🌱 Climate Solutions</span>
    </header>

    <main>
        {% for message in app.flashes('success') %}
            <ul class="flash-list">
                <li class="flash-success">{{ message }}</li>
            </ul>
        {% endfor %}

        <div class="page-heading">
            <h1>{{ calendar.name }}</h1>
            <p class="client-name">{{ calendar.client.name ?? calendar.client.email }}</p>
        </div>

        <div id="calendar-holder"></div>
    </main>

    <div class="booking-overlay" id="booking-overlay">
        <div class="booking-panel">
            <h3>Request Booking</h3>
            <div class="slot-info" id="booking-slot-info"></div>
            <form method="post" action="{{ path('calendar_public_book', {token: calendar.publicToken}) }}">
                <input type="hidden" name="slotId" id="booking-slotId">
                <input type="hidden" name="selectedDate" id="booking-selectedDate">
                <div class="form-row">
                    <div class="form-field">
                        <label for="booking-name">Your name</label>
                        <input type="text" id="booking-name" name="customerName" required maxlength="255" autocomplete="name">
                    </div>
                    <div class="form-field">
                        <label for="booking-email">Email address</label>
                        <input type="email" id="booking-email" name="customerEmail" required maxlength="255" autocomplete="email">
                    </div>
                    <div class="form-field form-field-full">
                        <label for="booking-message">Message (optional)</label>
                        <textarea id="booking-message" name="message" rows="3"></textarea>
                    </div>
                </div>
                <div class="booking-actions">
                    <button type="submit" class="btn-submit">Send Request</button>
                    <button type="button" class="btn-cancel" onclick="closeBooking()">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <footer>&copy; {{ "now"|date("Y") }} Climate Solutions</footer>

    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var cal = new FullCalendar.Calendar(document.getElementById('calendar-holder'), {
                initialView: 'dayGridMonth',
                height: 'auto',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,listMonth'
                },
                eventSources: [{
                    url: '/fc-load-events',
                    method: 'POST',
                    extraParams: {
                        filters: JSON.stringify({ token: '{{ calendar.publicToken }}', viewType: 'public' })
                    },
                    failure: function () { console.error('Failed to load calendar events.'); }
                }],
                eventColor: '#2d6a4f',
                eventClick: function (info) {
                    var props = info.event.extendedProps;
                    if (props.status !== 'open') return;

                    document.getElementById('booking-slotId').value = props.slotId;
                    document.getElementById('booking-selectedDate').value = props.date || '';

                    var infoText = '';
                    if (props.type === 'day') {
                        infoText = props.date;
                    } else if (props.timeRange) {
                        infoText = props.date + ' · ' + props.timeRange;
                    }
                    if (props.location) infoText += ' · 📍 ' + props.location;
                    if (props.continent) infoText += ' · ' + props.continent;
                    document.getElementById('booking-slot-info').textContent = infoText;

                    document.getElementById('booking-overlay').classList.add('is-open');
                },
            });
            cal.render();

            document.getElementById('booking-overlay').addEventListener('click', function (e) {
                if (e.target === this) closeBooking();
            });
        });

        function closeBooking() {
            document.getElementById('booking-overlay').classList.remove('is-open');
        }
    </script>
</body>
</html>

