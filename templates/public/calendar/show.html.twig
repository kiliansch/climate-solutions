<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ calendar.name }} — Climate Solutions</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: system-ui, -apple-system, sans-serif;
            background: #f0f4f0;
            color: #1b1b1b;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        header {
            background: #1b4332;
            color: #fff;
            padding: 1rem 2rem;
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        header .brand { font-weight: 700; font-size: 1.1rem; color: #95d5b2; text-decoration: none; }
        header .brand:hover { color: #fff; }
        main { flex: 1; padding: 2rem; max-width: 860px; margin: 0 auto; width: 100%; }
        footer {
            text-align: center;
            padding: 1rem;
            font-size: .875rem;
            color: #555;
            border-top: 1px solid #d8e8d8;
            margin-top: 3rem;
        }

        .page-heading { margin-bottom: 1.5rem; }
        .page-heading h1 { font-size: 1.6rem; font-weight: 700; color: #1b4332; }
        .page-heading .client-name { font-size: 1rem; color: #555; margin-top: .3rem; }

        .flash-list { list-style: none; margin-bottom: 1.25rem; }
        .flash-list li { padding: .75rem 1rem; border-radius: 4px; margin-bottom: .5rem; font-size: .9rem; }
        .flash-success { background: #d1fae5; color: #065f46; }

        .no-slots { color: #6b7280; font-style: italic; padding: 1.5rem 0; }

        .date-group { margin-bottom: 2rem; }
        .date-group__label {
            font-size: 1rem;
            font-weight: 700;
            color: #1b4332;
            border-bottom: 2px solid #d8e8d8;
            padding-bottom: .35rem;
            margin-bottom: .85rem;
        }
        .slot-card {
            background: #fff;
            border-radius: 6px;
            box-shadow: 0 1px 3px rgba(0,0,0,.08);
            padding: 1rem 1.125rem;
            margin-bottom: .75rem;
        }
        .slot-card__head {
            display: flex;
            align-items: center;
            gap: .75rem;
            flex-wrap: wrap;
        }
        .slot-card__time { font-weight: 600; font-size: .95rem; color: #1b1b1b; }
        .slot-card__meta { font-size: .82rem; color: #555; flex: 1; }
        .badge {
            display: inline-block;
            padding: .18rem .52rem;
            border-radius: 9999px;
            font-size: .68rem;
            font-weight: 700;
            letter-spacing: .04em;
            text-transform: uppercase;
        }
        .badge-day      { background: #fef3c7; color: #92400e; }
        .badge-time     { background: #ede9fe; color: #5b21b6; }
        .badge-continent { background: #dbeafe; color: #1e40af; }

        .btn-request {
            display: inline-block;
            padding: .35rem .8rem;
            background: #059669;
            color: #fff;
            border: none;
            border-radius: 4px;
            font-size: .82rem;
            font-weight: 600;
            cursor: pointer;
            white-space: nowrap;
        }
        .btn-request:hover { background: #047857; }
        .btn-request[aria-expanded="true"] { background: #6b7280; }

        .booking-form {
            display: none;
            margin-top: .85rem;
            padding-top: .85rem;
            border-top: 1px solid #e8f0e8;
        }
        .booking-form.is-open { display: block; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem; margin-bottom: .75rem; }
        .form-field label { display: block; font-size: .78rem; font-weight: 600; margin-bottom: .25rem; color: #374151; }
        .form-field input,
        .form-field textarea {
            width: 100%;
            padding: .4rem .6rem;
            border: 1px solid #d1d5db;
            border-radius: 4px;
            font-size: .875rem;
        }
        .form-field textarea { resize: vertical; min-height: 64px; }
        .form-field-full { grid-column: 1 / -1; }
        .btn-submit {
            background: #1b4332;
            color: #fff;
            border: none;
            border-radius: 4px;
            padding: .45rem .95rem;
            font-size: .875rem;
            font-weight: 600;
            cursor: pointer;
        }
        .btn-submit:hover { background: #155724; }
    </style>
</head>
<body>
    <header>
        <span class="brand">🌱 Climate Solutions</span>
    </header>

    <main>
        {% for message in app.flashes('success') %}
            <ul class="flash-list">
                <li class="flash-success">{{ message }}</li>
            </ul>
        {% endfor %}

        <div class="page-heading">
            <h1>{{ calendar.name }}</h1>
            <p class="client-name">{{ calendar.client.name ?? calendar.client.email }}</p>
        </div>

        {% if slots is empty %}
            <p class="no-slots">No available slots at the moment. Please check back later.</p>
        {% else %}
            {% set current_date = null %}
            {% for slot in slots %}
                {% set slot_date_key = slot.startAt|date('Y-m-d') %}
                {% set slot_date_label = slot.startAt|date('l, d F Y') %}

                {% if slot_date_key != current_date %}
                    {% if current_date is not null %}</div>{% endif %}
                    <div class="date-group">
                    <div class="date-group__label">{{ slot_date_label }}</div>
                    {% set current_date = slot_date_key %}
                {% endif %}

                <div class="slot-card">
                    <div class="slot-card__head">
                        {% if slot.type == 'day' %}
                            <span class="slot-card__time">Full day</span>
                            <span class="badge badge-day">Day</span>
                        {% else %}
                            <span class="slot-card__time">
                                {{ slot.startAt|date('H:i') }} – {{ slot.endAt|date('H:i') }}
                            </span>
                            <span class="badge badge-time">Time block</span>
                        {% endif %}
                        {% if slot.continent %}
                            <span class="badge badge-continent">{{ slot.continent }}</span>
                        {% endif %}
                        {% if slot.location %}
                            <span class="slot-card__meta">📍 {{ slot.location }}</span>
                        {% endif %}
                        <button
                            type="button"
                            class="btn-request"
                            aria-expanded="false"
                            aria-controls="booking-form-{{ slot.id }}"
                            onclick="toggleBookingForm(this, 'booking-form-{{ slot.id }}')"
                        >Request Booking</button>
                    </div>

                    <div class="booking-form" id="booking-form-{{ slot.id }}">
                        <form method="post" action="{{ path('calendar_public_book', {token: calendar.publicToken}) }}">
                            <input type="hidden" name="slotId" value="{{ slot.id }}">
                            <div class="form-row">
                                <div class="form-field">
                                    <label for="name-{{ slot.id }}">Your name</label>
                                    <input
                                        type="text"
                                        id="name-{{ slot.id }}"
                                        name="customerName"
                                        required
                                        maxlength="255"
                                        autocomplete="name"
                                    >
                                </div>
                                <div class="form-field">
                                    <label for="email-{{ slot.id }}">Email address</label>
                                    <input
                                        type="email"
                                        id="email-{{ slot.id }}"
                                        name="customerEmail"
                                        required
                                        maxlength="255"
                                        autocomplete="email"
                                    >
                                </div>
                                <div class="form-field form-field-full">
                                    <label for="message-{{ slot.id }}">Message (optional)</label>
                                    <textarea id="message-{{ slot.id }}" name="message" rows="3"></textarea>
                                </div>
                            </div>
                            <button type="submit" class="btn-submit">Send Request</button>
                        </form>
                    </div>
                </div>

            {% endfor %}
            {% if current_date is not null %}</div>{% endif %}
        {% endif %}
    </main>

    <footer>&copy; {{ "now"|date("Y") }} Climate Solutions</footer>

    <script>
        function toggleBookingForm(btn, formId) {
            const form = document.getElementById(formId);
            const isOpen = form.classList.toggle('is-open');
            btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
            btn.textContent = isOpen ? 'Cancel' : 'Request Booking';
        }
    </script>
</body>
</html>

