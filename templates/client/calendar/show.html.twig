{% extends 'base.html.twig' %}

{% block title %}My Calendar — {{ calendar.name }}{% endblock %}

{% block stylesheets %}
<style>
    h1 { font-size: 1.5rem; font-weight: 700; color: #1b4332; margin-bottom: 1.25rem; }
    h2 { font-size: 1.125rem; font-weight: 700; color: #1b4332; margin: 1.5rem 0 .75rem; }
    h2:first-child { margin-top: 0; }

    .warning-banner {
        background: #fef3c7;
        color: #92400e;
        border: 1px solid #fcd34d;
        border-radius: 6px;
        padding: .85rem 1rem;
        margin-bottom: 1.25rem;
        font-size: .875rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    #calendar-holder {
        background: #fff;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
        padding: 1.5rem;
        margin-bottom: 2rem;
    }
    .fc-toolbar-title { color: #1b4332 !important; }
    .fc-button-primary {
        background-color: #2d6a4f !important;
        border-color: #2d6a4f !important;
    }
    .fc-button-primary:hover {
        background-color: #1b4332 !important;
        border-color: #1b4332 !important;
    }
    .fc-button-active {
        background-color: #1b4332 !important;
        border-color: #1b4332 !important;
    }
    .fc-daygrid-event { border-radius: 4px; }
    .cal-legend { display: flex; gap: 1.25rem; font-size: .78rem; margin-top: .75rem; }
    .cal-legend span { display: flex; align-items: center; gap: .35rem; }
    .cal-legend i { display: inline-block; width: 12px; height: 12px; border-radius: 3px; }

    table {
        width: 100%;
        border-collapse: collapse;
        background: #fff;
        border-radius: 6px;
        overflow: hidden;
        box-shadow: 0 1px 3px rgba(0,0,0,.1);
        margin-bottom: 1.5rem;
    }
    th, td {
        padding: .75rem 1rem;
        text-align: left;
        font-size: .875rem;
        border-bottom: 1px solid #e8f0e8;
        vertical-align: middle;
    }
    th { background: #1b4332; color: #fff; font-weight: 600; }
    tr:last-child td { border-bottom: none; }
    .empty-row td { color: #6b7280; font-style: italic; text-align: center; padding: 2rem; }

    .add-form {
        background: #fff;
        border-radius: 6px;
        box-shadow: 0 1px 3px rgba(0,0,0,.1);
        padding: 1.25rem;
    }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: .85rem; margin-bottom: .85rem; }
    .form-row-3 { grid-template-columns: 1fr 1fr 1fr; }
    .form-field label { display: block; font-size: .78rem; font-weight: 600; margin-bottom: .25rem; color: #374151; }
    .form-field input,
    .form-field textarea {
        width: 100%;
        padding: .4rem .6rem;
        border: 1px solid #d1d5db;
        border-radius: 4px;
        font-size: .875rem;
        background: #fff;
    }
    .form-field textarea { resize: vertical; min-height: 60px; }

    .btn { display: inline-block; padding: .4rem .85rem; border-radius: 4px; font-size: .85rem; font-weight: 600; cursor: pointer; text-decoration: none; border: none; }
    .btn-primary { background: #1b4332; color: #fff; }
    .btn-primary:hover { background: #155724; }
    .btn-danger  { background: #dc2626; color: #fff; }
    .btn-danger:hover  { background: #b91c1c; }
    .btn-sm { padding: .25rem .55rem; font-size: .78rem; }
</style>
{% endblock %}

{% block body %}
<h1>{{ calendar.name }}</h1>

{% if hasOverriddenSlots %}
<div class="warning-banner">
    ⚠️ One or more of your unavailability periods have overridden agent-opened slots. Any affected bookings have been cancelled.
</div>
{% endif %}

<div id="calendar-holder"></div>
<div class="cal-legend">
    <span><i style="background:#2d6a4f"></i> Open slot</span>
    <span><i style="background:#fbbf24"></i> Blocked day</span>
    <span><i style="background:#9ca3af"></i> Overridden</span>
    <span><i style="background:#dc2626"></i> Unavailability</span>
</div>

<h2>Your Unavailability Blocks</h2>
<table>
    <thead>
        <tr>
            <th>From</th>
            <th>To</th>
            <th>Reason</th>
            <th>Affected Days</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        {% for block in unavailabilities %}
        <tr>
            <td>{{ block.startAt|date('Y-m-d') }}</td>
            <td>{{ block.endAt|date('Y-m-d') }}</td>
            <td>{{ block.reason ?? '—' }}</td>
            <td>
                {% if blockedDatesByUnavailability[block.id] is defined and blockedDatesByUnavailability[block.id] is not empty %}
                    {% for date in blockedDatesByUnavailability[block.id] %}
                        <span style="display:inline-block;background:#fef3c7;color:#92400e;padding:0 .4rem;border-radius:3px;font-size:.78rem;margin:1px">{{ date|date('Y-m-d') }}</span>
                    {% endfor %}
                {% else %}
                    —
                {% endif %}
            </td>
            <td>
                <form method="post" action="{{ path('client_unavailability_delete', {id: block.id}) }}" style="display:inline">
                    <input type="hidden" name="_method" value="DELETE">
                    <button type="submit" class="btn btn-danger btn-sm"
                        onclick="return confirm('Remove this unavailability block?')">Delete</button>
                </form>
            </td>
        </tr>
        {% else %}
        <tr class="empty-row">
            <td colspan="5">No unavailability blocks set.</td>
        </tr>
        {% endfor %}
    </tbody>
</table>

<h2>Add Unavailability</h2>
<div class="add-form">
    <form method="post" action="{{ path('client_unavailability_create') }}">
        <div class="form-row form-row-3">
            <div class="form-field">
                <label for="startAt">From (date)</label>
                <input type="date" id="startAt" name="startAt" required>
            </div>
            <div class="form-field">
                <label for="endAt">To (date)</label>
                <input type="date" id="endAt" name="endAt" required>
            </div>
            <div class="form-field">
                <label for="reason">Reason (optional)</label>
                <input type="text" id="reason" name="reason" maxlength="255" placeholder="e.g. Vacation">
            </div>
        </div>
        <button type="submit" class="btn btn-primary">Add Unavailability</button>
    </form>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        new FullCalendar.Calendar(document.getElementById('calendar-holder'), {
            initialView: 'dayGridMonth',
            height: 'auto',
            headerToolbar: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth,listMonth'
            },
            eventSources: [{
                url: '/fc-load-events',
                method: 'POST',
                extraParams: {
                    filters: JSON.stringify({ token: '{{ calendar.publicToken }}', viewType: 'client' })
                },
                failure: function () { console.error('Failed to load calendar events.'); }
            }],
            eventColor: '#2d6a4f',
        }).render();

        // Ensure endAt >= startAt
        document.getElementById('startAt').addEventListener('change', function () {
            var end = document.getElementById('endAt');
            if (end.value && end.value < this.value) {
                end.value = this.value;
            }
            end.min = this.value;
        });
    });
</script>
{% endblock %}
