{% extends 'base.html.twig' %}

{% block title %}Activate Account — Climate Solutions{% endblock %}

{% block stylesheets %}
<style>
    .auth-card {
        max-width: 460px;
        margin: 3rem auto;
        background: #fff;
        border-radius: 8px;
        padding: 2rem;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
    }
    .auth-card h1 {
        font-size: 1.5rem;
        margin-bottom: .5rem;
        color: #1b4332;
    }
    .auth-card .subtitle {
        font-size: .9rem;
        color: #555;
        margin-bottom: 1.5rem;
    }
    .form-group {
        margin-bottom: 1rem;
    }
    .form-group label {
        display: block;
        font-size: .875rem;
        font-weight: 600;
        margin-bottom: .25rem;
        color: #333;
    }
    .form-group input {
        width: 100%;
        padding: .5rem .75rem;
        border: 1px solid #ccc;
        border-radius: 4px;
        font-size: 1rem;
        transition: border-color .15s;
    }
    .form-group input:focus {
        outline: none;
        border-color: #1b4332;
    }
    .form-group input[readonly] {
        background: #f3f4f6;
        color: #555;
        cursor: default;
    }
    .btn-primary {
        width: 100%;
        padding: .625rem;
        background: #1b4332;
        color: #fff;
        border: none;
        border-radius: 4px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        margin-top: .5rem;
    }
    .btn-primary:hover { background: #2d6a4f; }
    .notice {
        padding: .65rem 1rem;
        border-radius: 4px;
        background: #fef9c3;
        color: #713f12;
        font-size: .875rem;
        margin-top: 1.25rem;
    }
    .field-error {
        color: #991b1b;
        font-size: .8rem;
        margin-top: .2rem;
    }
</style>
{% endblock %}

{% block body %}
<div class="auth-card">
    <h1>Activate Account</h1>
    <p class="subtitle">Set a password to complete your registration.</p>

    <form method="post" action="{{ path('app_invite_accept_post', { token: token }) }}">
        <div class="form-group">
            <label for="email">Email address</label>
            <input
                type="email"
                id="email"
                name="email"
                value="{{ email }}"
                readonly
            >
        </div>

        <div class="form-group">
            <label for="password">Password <small>(min. 8 characters)</small></label>
            <input
                type="password"
                id="password"
                name="password"
                autocomplete="new-password"
                minlength="8"
                required
                autofocus
            >
        </div>

        <div class="form-group">
            <label for="confirm_password">Confirm password</label>
            <input
                type="password"
                id="confirm_password"
                name="confirm_password"
                autocomplete="new-password"
                minlength="8"
                required
            >
            <p class="field-error" id="pwd-match-error" style="display:none;">Passwords do not match.</p>
        </div>

        <button type="submit" class="btn-primary">Activate Account</button>
    </form>

    <p class="notice">
        ⏳ This invitation link expires after <strong>7 days</strong>. Please activate your account before it expires.
    </p>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function () {
    var form = document.querySelector('form');
    var pwd = document.getElementById('password');
    var confirm = document.getElementById('confirm_password');
    var error = document.getElementById('pwd-match-error');

    form.addEventListener('submit', function (e) {
        if (pwd.value !== confirm.value) {
            e.preventDefault();
            error.style.display = 'block';
            confirm.focus();
        }
    });

    confirm.addEventListener('input', function () {
        error.style.display = pwd.value && confirm.value && pwd.value !== confirm.value ? 'block' : 'none';
    });
}());
</script>
{% endblock %}
