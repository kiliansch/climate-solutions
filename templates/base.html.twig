<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Climate Solutions{% endblock %}</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: system-ui, -apple-system, sans-serif;
            background: #f0f4f0;
            color: #1b1b1b;
        }
        header {
            background: #1b4332;
            color: #fff;
            padding: 1rem 2rem;
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        header a { color: #95d5b2; text-decoration: none; font-weight: 600; }
        header a:hover { color: #fff; }
        nav { margin-left: auto; display: flex; align-items: center; gap: 1.5rem; }
        .user-info { display: flex; align-items: center; gap: .75rem; font-size: .875rem; }
        .role-badge {
            display: inline-block;
            padding: .2rem .55rem;
            border-radius: 9999px;
            font-size: .7rem;
            font-weight: 700;
            letter-spacing: .04em;
            text-transform: uppercase;
        }
        .role-badge.admin  { background: #b91c1c; color: #fff; }
        .role-badge.agent  { background: #1d4ed8; color: #fff; }
        .role-badge.client { background: #15803d; color: #fff; }
        .btn-logout {
            padding: .35rem .75rem;
            background: transparent;
            border: 1px solid #95d5b2;
            border-radius: 4px;
            color: #95d5b2;
            font-size: .875rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
        }
        .btn-logout:hover { background: #95d5b2; color: #1b4332; }
        main { padding: 2rem; max-width: 1200px; margin: 0 auto; }
        .flash-list { list-style: none; margin-bottom: 1.25rem; }
        .flash-list li {
            padding: .75rem 1rem;
            border-radius: 4px;
            margin-bottom: .5rem;
            font-size: .9rem;
        }
        .flash-success { background: #d1fae5; color: #065f46; }
        .flash-error   { background: #fee2e2; color: #991b1b; }
        .flash-info    { background: #dbeafe; color: #1e40af; }
        footer {
            text-align: center;
            padding: 1rem;
            font-size: .875rem;
            color: #555;
            border-top: 1px solid #d8e8d8;
            margin-top: 3rem;
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <header>
        <strong>🌱 Climate Solutions</strong>
        <nav>
            {% if is_granted('ROLE_AGENT') %}
                <a href="{{ path('agent_calendar_list') }}">My Calendars</a>
                <a href="{{ path('agent_booking_list') }}">Booking Requests</a>
            {% endif %}
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('admin_agent_list') }}">Agents</a>
            {% endif %}
            {% if is_granted('ROLE_CLIENT') and not is_granted('ROLE_AGENT') and not is_granted('ROLE_ADMIN') %}
                <a href="/client/calendar">My Calendar</a>
            {% endif %}
            {% if app.user %}
                <span class="user-info">
                    <span>{{ app.user.name ?? app.user.userIdentifier }}</span>
                    {% if is_granted('ROLE_ADMIN') %}
                        <span class="role-badge admin">Admin</span>
                    {% elseif is_granted('ROLE_AGENT') %}
                        <span class="role-badge agent">Agent</span>
                    {% else %}
                        <span class="role-badge client">Client</span>
                    {% endif %}
                    <a class="btn-logout" href="{{ path('app_logout') }}">Logout</a>
                </span>
            {% endif %}
        </nav>
    </header>

    <main>
        {% for type, messages in app.flashes(['success', 'error', 'info']) %}
            <ul class="flash-list">
                {% for message in messages %}
                    <li class="flash-{{ type }}">{{ message }}</li>
                {% endfor %}
            </ul>
        {% endfor %}

        {% block body %}{% endblock %}
    </main>

    <footer>&copy; {{ "now"|date("Y") }} Climate Solutions</footer>

    {% block javascripts %}{% endblock %}
</body>
</html>
